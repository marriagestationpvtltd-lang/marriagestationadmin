# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── MySQL (same credentials as your PHP backend) ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (Flutter web URL etc.)
ALLOWED_ORIGINS=https://digitallami.com,http://localhost:3000

# ── Internal emit secret (PHP → Node.js bridge) ───────────────────────────────
INTERNAL_SECRET=change_me_to_a_strong_secret
